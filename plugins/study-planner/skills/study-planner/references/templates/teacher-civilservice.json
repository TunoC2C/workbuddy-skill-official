{
  "id": "teacher-civilservice",
  "name": "教师资格证 / 公务员考试计划",
  "description": "适用于教师资格证、公务员考试（行测+申论）、事业单位考试",
  "applicable_to": ["教师资格证", "国考", "省考", "事业单位", "选调生"],
  "default_duration_days": 100,
  "total_phases": 3,

  "exam_subtypes": [
    {
      "type": "教师资格证",
      "subjects": ["综合素质", "教育知识与能力", "学科知识与能力（中学）", "保教知识与能力（幼儿园）"],
      "key_focus": ["材料分析题", "教学设计", "案例分析", "作文"],
      "pass_threshold": "70/120 (70%)"
    },
    {
      "type": "公务员（国考/省考）",
      "subjects": ["行测", "申论"],
      "key_focus": ["言语理解", "数量关系", "判断推理", "资料分析", "常识", "申论 5 题型"],
      "pass_threshold": "进面：行测 65+ / 申论 60+"
    }
  ],

  "phase_templates": [
    {
      "phase": 1,
      "name": "基础打底（理论+模块）",
      "duration_ratio": 0.4,
      "description": "知识体系搭建 + 各模块单项突破",
      "weekly_pattern": [
        { "day": "Mon", "tasks": ["教综/言语理解 1 章", "刷题 30 道", "知识点笔记"] },
        { "day": "Tue", "tasks": ["教育知识/判断推理 1 章", "刷题 30 道"] },
        { "day": "Wed", "tasks": ["学科知识/数量关系", "易错题整理"] },
        { "day": "Thu", "tasks": ["教学设计/资料分析", "套题 20 道"] },
        { "day": "Fri", "tasks": ["作文/申论小题", "模板积累"] },
        { "day": "Sat", "tasks": ["弱项专项突破", "错题二刷"] },
        { "day": "Sun", "tasks": ["艾宾浩斯复现", "笔记体系化", "下周规划"] }
      ]
    },
    {
      "phase": 2,
      "name": "模块强化（套题+技巧）",
      "duration_ratio": 0.35,
      "description": "限时套题 + 解题技巧 + 时间管理",
      "weekly_pattern": [
        { "day": "Mon", "tasks": ["行测/教综限时套题", "错题分析"] },
        { "day": "Tue", "tasks": ["申论/学科 1 套", "答题模板内化"] },
        { "day": "Wed", "tasks": ["薄弱模块专项", "高频考点二轮"] },
        { "day": "Thu", "tasks": ["综合套题", "时间分配训练"] },
        { "day": "Fri", "tasks": ["作文/教学设计 1 篇", "批改互评"] },
        { "day": "Sat", "tasks": ["全真模拟", "错题深度分析"] },
        { "day": "Sun", "tasks": ["热点积累（时政/教育热点）", "复盘"] }
      ]
    },
    {
      "phase": 3,
      "name": "冲刺模考",
      "duration_ratio": 0.25,
      "description": "全真模考 + 押题 + 心态调整",
      "weekly_pattern": [
        { "day": "Mon", "tasks": ["全真模考", "错题三刷"] },
        { "day": "Tue", "tasks": ["申论/作文押题", "模板背诵"] },
        { "day": "Wed", "tasks": ["行测 + 教综限时", "节奏调整"] },
        { "day": "Thu", "tasks": ["全真模考", "心态训练"] },
        { "day": "Fri", "tasks": ["时政热点最后一轮", "考点回顾"] },
        { "day": "Sat", "tasks": ["最后一套模考", "准备物品"] },
        { "day": "Sun", "tasks": ["休息 + 复习易错点", "早睡"] }
      ]
    }
  ],

  "methodology_injection": {
    "ebbinghaus": true,
    "pomodoro": true,
    "pareto": true,
    "feynman": false,
    "description": "公考教资重在二八法则抓高频，艾宾浩斯复现错题，番茄钟保持专注，作文/申论需要模板内化"
  },

  "special_notes": [
    "行测：先放弃数量关系超难题，保证言语理解 + 资料分析全对",
    "申论：抄写优秀范文 ≥ 10 篇，内化语感",
    "教资：综合素质作文是大头，文化常识必须积累",
    "时政热点每天 15 分钟，临考前 1 个月重点关注",
    "面试可单独留 1 个月（公考进面后）",
    "考前不要做新题，回顾错题本即可"
  ]
}
